# SurrealDB database name (string). Examples: memory, testdb, production_db
SURREALDB_DB_NAME=memory

# SurrealDB connection URL (WebSocket RPC). If omitted/empty, embedded RocksDB mode will be used.
# Format: ws://HOST:PORT/rpc or wss://HOST:PORT/rpc
SURREALDB_URL=ws://127.0.0.1:8000/rpc

# Comma-separated namespaces (must include at least one). Example: org,personal,private
SURREALDB_NAMESPACES=org,personal,private

# SurrealDB credentials
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root

# Logging level. Allowed: trace | debug | info | warn | error
LOG_LEVEL=info

# Optional: force embedded engine (true|false). Prefer to leave unset and rely on SURREALDB_URL inference.
SURREALDB_EMBEDDED=true

# Optional: data directory for embedded RocksDB (used when embedded=true or when SURREALDB_URL is not set)
# SURREALDB_DATA_DIR=./data/surrealdb

# Optional: embedding dimension for HNSW indexes.
# Common values:
# - text-embedding-3-small = 1536
# - nomic-embed-text = 768
# - mxbai-embed-large = 1024
# If you change this for an existing database, drop and recreate the embedding
# indexes (or rebuild the DB) before writing vectors with the new dimension.
# SURREALDB_EMBEDDING_DIMENSION=1536

# Optional semantic embedding integration (disabled by default).
# Without this, the MCP still works fully using lexical + community retrieval.
EMBEDDINGS_ENABLED=false

# Provider kind: openai-compatible | ollama
# EMBEDDINGS_PROVIDER=openai-compatible

# Provider API base URL.
# OpenAI-compatible default: https://api.openai.com/v1
# Ollama default: http://127.0.0.1:11434
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1

# Model name sent to the provider.
# EMBEDDINGS_MODEL=text-embedding-3-small

# Optional bearer token for OpenAI-compatible providers.
# EMBEDDINGS_API_KEY=your_api_key_here

# Embedding request timeout in seconds.
# EMBEDDINGS_TIMEOUT_SECS=15

# Minimum cosine similarity required for semantic matches.
# Raise this to reduce false positives; lower it to increase recall.
# EMBEDDINGS_SIMILARITY_THRESHOLD=0.7

# Lifecycle background jobs (disabled by default)
# Enable background workers for memory hygiene (decay + archival)
LIFECYCLE_ENABLED=false

# Interval for decay worker (seconds) - how often to check for stale facts
LIFECYCLE_DECAY_INTERVAL_SECS=3600

# Interval for archival worker (seconds) - how often to archive old episodes
LIFECYCLE_ARCHIVAL_INTERVAL_SECS=86400

# Confidence threshold below which facts are marked invalid (0.0-1.0)
LIFECYCLE_DECAY_THRESHOLD=0.3

# Days after which episodes without active facts are archived
LIFECYCLE_ARCHIVAL_AGE_DAYS=90
