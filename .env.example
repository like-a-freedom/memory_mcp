# =============================================================================
# MEMORY MCP — ENVIRONMENT VARIABLES REFERENCE
# =============================================================================

# -----------------------------------------------------------------------------
# SURREALDB CONFIGURATION
# -----------------------------------------------------------------------------

# Database name (string).
# Examples: memory, testdb, production_db
# Required: Yes
SURREALDB_DB_NAME=memory

# Connection URL for SurrealDB.
# Formats (remote mode only):
#   - WebSocket:     ws://HOST:PORT/rpc
#   - WebSocket SSL: wss://HOST:PORT/rpc
# Required: Yes when SURREALDB_EMBEDDED=false. Ignored in embedded mode.
SURREALDB_URL=ws://127.0.0.1:8000/rpc

# Comma-separated list of namespaces to initialize.
# Must include at least one namespace.
# Examples: org, org,personal, org,personal,private
# Required: Yes
SURREALDB_NAMESPACES=org,personal,private

# Database credentials.
# Required: Yes
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------------------

# Logging level (standard RUST_LOG environment variable).
# Allowed values: trace, debug, info, warn, error
# Default: info
# Required: No
RUST_LOG=info

# -----------------------------------------------------------------------------
# STORAGE CONFIGURATION
# -----------------------------------------------------------------------------

# Force embedded RocksDB engine.
# Allowed values: true, false
# Default: false
# Required: No
SURREALDB_EMBEDDED=true

# Custom data directory for embedded RocksDB.
# Used when SURREALDB_EMBEDDED=true.
# Default: <directory of running executable>/data/surrealdb
# Required: No
# SURREALDB_DATA_DIR=./data/surrealdb

# -----------------------------------------------------------------------------
# EMBEDDING CONFIGURATION
# -----------------------------------------------------------------------------

# Expected embedding vector dimension for HNSW indexes.
# Common model dimensions:
#   - 384   → intfloat/multilingual-e5-small (default local model)
#   - 768   → nomic-embed-text, mxbai-embed-base
#   - 1024  → mxbai-embed-large
#   - 1536  → text-embedding-3-small (OpenAI)
#   - 2048  → some custom models
#   - 3072  → text-embedding-3-large (OpenAI)
# Default: 384 when unset and embeddings are enabled
# Required: No
# Note: If you change this for an existing database, rebuild/drop-and-recreate
#       the embedding indexes before writing vectors with the new dimension.
# SURREALDB_EMBEDDING_DIMENSION=384

# Enable semantic embedding integration.
# When false, the MCP still works using lexical + community retrieval only.
# Allowed values: true, false
# Default: true
# Required: No
# EMBEDDINGS_ENABLED=true

# Embedding provider kind.
# Allowed values: local-candle, openai-compatible, ollama
# Default: local-candle
# Required: No (only when overriding the default provider)
# EMBEDDINGS_PROVIDER=local-candle

# Provider API base URL.
# Examples:
#   - Local Candle:       not used
#   - OpenAI-compatible: https://api.openai.com/v1
#   - Ollama:            http://127.0.0.1:11434
# Default (OpenAI-compatible): https://api.openai.com/v1
# Default (Ollama):            http://127.0.0.1:11434
# Required: No for local-candle; optional for openai-compatible/ollama if using the defaults
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1

# Embedding model name.
# Examples:
#   - Local Candle: intfloat/multilingual-e5-small
#   - OpenAI: text-embedding-3-small, text-embedding-3-large
#   - Ollama: nomic-embed-text, mxbai-embed-large
# Default (local-candle): intfloat/multilingual-e5-small
# Required: Yes for openai-compatible/ollama; optional for local-candle
# EMBEDDINGS_MODEL=intfloat/multilingual-e5-small

# Override local embedding model cache directory.
# Default: <data_dir>/models/<model_repo_id>
# Required: No
# EMBEDDINGS_MODEL_DIR=./data/models/intfloat/multilingual-e5-small

# API key for OpenAI-compatible providers (bearer token).
# Required: Depends on provider (typically required for OpenAI-compatible, unused for local-candle, optional for local gateways)
# EMBEDDINGS_API_KEY=your_api_key_here

# Embedding request timeout in seconds.
# Default: 15
# Required: No
# EMBEDDINGS_TIMEOUT_SECS=15

# Minimum cosine similarity threshold for semantic retrieval.
# Range: 0.0 (any match) to 1.0 (exact match only)
# Raise to reduce false positives; lower to increase recall.
# Default: 0.7
# Required: No
# EMBEDDINGS_SIMILARITY_THRESHOLD=0.7

# Maximum input tokens for embedding.
# Used for chunking long texts to stay within model limits.
# For local-candle (BERT): max 512, default 384 (80% for safety)
# Chunk size is auto-calculated as 80% of this value.
# Overlap is auto-calculated as 10% of chunk size.
# Default: 384
# Required: No
# EMBEDDINGS_MAX_TOKENS=384

# -----------------------------------------------------------------------------
# LIFECYCLE CONFIGURATION (BACKGROUND JOBS)
# Disabled by default — enable for production deployments
# -----------------------------------------------------------------------------

# Enable background workers for memory hygiene (decay + archival).
# Allowed values: true, false
# Default: false
# Required: No
LIFECYCLE_ENABLED=false

# Interval for decay worker (how often to check for stale facts).
# Unit: seconds
# Default: 3600 (1 hour)
# Required: No
LIFECYCLE_DECAY_INTERVAL_SECS=3600

# Interval for archival worker (how often to archive old episodes).
# Unit: seconds
# Default: 86400 (24 hours)
# Required: No
LIFECYCLE_ARCHIVAL_INTERVAL_SECS=86400

# Confidence threshold below which facts are marked as invalid.
# Range: 0.0 to 1.0
# Default: 0.3
# Required: No
LIFECYCLE_DECAY_THRESHOLD=0.3

# Days after which episodes without active facts are archived.
# Default: 90
# Required: No
LIFECYCLE_ARCHIVAL_AGE_DAYS=90

# Half-life in days for confidence decay computation.
# Default: 365
# Required: No
# LIFECYCLE_DECAY_HALF_LIFE_DAYS=365

# -----------------------------------------------------------------------------
# NER CONFIGURATION (NAMED ENTITY RECOGNITION)
# Optional — defaults to heuristic 'anno' provider
# -----------------------------------------------------------------------------

# NER provider backend.
# Allowed values: regex, anno, local-gliner
#   - regex: Simple regex-based extraction (fast, no model)
#   - anno:  Heuristic annotation-based extraction (default)
#   - local-gliner: DeBERTa-v3 based zero-shot extraction (downloads model)
# Default: anno
# Required: No
# NER_PROVIDER=anno

# HuggingFace model repo for local-gliner provider.
# Primary: urchade/gliner_multi-v2.1 (multilingual GLiNER on DeBERTa-v3)
# Default: urchade/gliner_multi-v2.1
# Required: No (only if NER_PROVIDER=local-gliner)
# NER_MODEL=urchade/gliner_multi-v2.1

# Override model cache directory.
# Default: <data_dir>/models/ner/<model_repo_id_with_slashes_replaced_by_double-dashes>
# Required: No
# NER_MODEL_DIR=./data/models/ner/urchade--gliner_multi-v2.1

# Comma-separated entity labels for extraction.
# Applied to local-gliner provider (runtime labels).
# Default: person,company,location,product,event,technology
# Required: No
# NER_LABELS=person,company,location,product,event,technology,date

# Confidence threshold for entity acceptance (0.0 to 1.0).
# Lower values = more entities, higher false positive rate.
# Higher values = fewer entities, higher precision.
# Default: 0.5
# Required: No
# NER_THRESHOLD=0.5

# Batch size for local-gliner inference (CPU optimization).
# Higher values use more memory but may be faster for bulk processing.
# Default: 4
# Required: No
# NER_BATCH_SIZE=4
